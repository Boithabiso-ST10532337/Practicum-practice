<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="386dp"
        android:layout_height="302dp"
        app:srcCompat="@drawable/randfontein"
        tools:layout_editor_absoluteX="12dp"
        tools:layout_editor_absoluteY="3dp" />

    <ImageView
        android:id="@+id/imageView4"
        android:layout_width="247dp"
        android:layout_height="222dp"
        app:srcCompat="@drawable/randfontein__1_"
        tools:layout_editor_absoluteX="82dp"
        tools:layout_editor_absoluteY="215dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnReport"
        android:layout_width="162dp"
        android:layout_height="57dp"
        android:background="#4D9750"
        android:backgroundTint="#325733"
        android:text="Weather report"
        android:visibility="visible"
        app:iconTint="#235725"
        tools:layout_editor_absoluteX="29dp"
        tools:layout_editor_absoluteY="515dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnExit"
        android:layout_width="164dp"
        android:layout_height="57dp"
        android:background="#4CAF50"
        android:text="Exit app"
        tools:layout_editor_absoluteX="218dp"
        tools:layout_editor_absoluteY="515dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/textView"
        android:layout_width="136dp"
        android:layout_height="36dp"
        android:text="Boithabiso Pooe"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="688dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/textView2"
        android:layout_width="101dp"
        android:layout_height="32dp"
        android:text="ST10532337"
        tools:layout_editor_absoluteX="165dp"
        tools:layout_editor_absoluteY="688dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>