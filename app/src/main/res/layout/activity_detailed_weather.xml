<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DetailedWeather">

    <Button
        android:id="@+id/button"
        android:layout_width="315dp"
        android:layout_height="64dp"
        android:text="Show detailed temperature"
        tools:layout_editor_absoluteX="48dp"
        tools:layout_editor_absoluteY="511dp" />

    <Button
        android:id="@+id/button2"
        android:layout_width="315dp"
        android:layout_height="63dp"
        android:text="Exit app"
        tools:layout_editor_absoluteX="48dp"
        tools:layout_editor_absoluteY="583dp" />

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Weather Summary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtAverage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Average Temperature:"
        android:textSize="18sp"
        android:layout_marginBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtHighest"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Highest Temperature:"
        android:textSize="18sp"
        android:layout_marginBottom="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>